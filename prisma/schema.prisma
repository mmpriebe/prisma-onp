
generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id String @id @default(uuid())
  name String 
  email String
  password String
  phone String?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  @@map("users")
}

model Post {
  id String @id @default(uuid())
  id_user String
  name String
  content String @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  @@map("posts")
}

